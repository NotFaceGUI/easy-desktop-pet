{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Easy Desktop Pet",
  "version": "0.1.0",
  "identifier": "com.notface.easydesktoppet",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM4QjBCRTcyRjQ1MTQ1RkIKUldUN1JWSDBjcjZ3T0xhK0tPaFRlcFJDdEMxUGFkWUJyM0p0Z2hwbzJRYms2M29XcDRqMkNGdFgK",
      "endpoints": [
        "https://github.com/NotFaceGUI/easy-desktop-pet/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "../public/assets/cat-idle.gif"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
